# Backend Environment Variables Template
# Copy this to your deployment platform and fill in actual values

# ============================================
# REQUIRED - Spotify API Credentials
# ============================================
SPOTIPY_CLIENT_ID=your_spotify_client_id_here
SPOTIPY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIPY_REDIRECT_URI=https://your-backend-domain.com/callback

# ============================================
# REQUIRED - Security
# ============================================
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
FLASK_SECRET=your_strong_random_secret_key_here

# ============================================
# REQUIRED - Frontend URL
# ============================================
FRONTEND_URL=https://your-frontend-domain.com

# ============================================
# REQUIRED - Environment
# ============================================
# Values: "dev" or "prod"
ENV=prod

# ============================================
# OPTIONAL - Redis for Session Storage
# ============================================
# Only if you want to use Redis instead of filesystem
# REDIS_URL=redis://your-redis-url:6379

# ============================================
# IMPORTANT: Update These After Setting Up Domains
# ============================================
# 1. After deploying backend to Render:
#    - Update SPOTIPY_REDIRECT_URI to your Render URL
#
# 2. After deploying frontend to Vercel:
#    - Update FRONTEND_URL to your Vercel URL
#    - Add VITE_API_BASE_URL in Vercel environment (set to your Render URL)
#
# 3. In Spotify Developer Dashboard:
#    - Whitelist SPOTIPY_REDIRECT_URI under "Redirect URIs"
